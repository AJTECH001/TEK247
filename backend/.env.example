# Server
NODE_ENV=development
PORT=5000

# PostgreSQL — individual vars used by the app pool
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tek247_db
DB_USER=postgres
DB_PASSWORD=your_password

# DATABASE_URL — used by dbmate CLI for migrations
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/tek247_db?sslmode=disable

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ORIGIN=http://localhost:5173
