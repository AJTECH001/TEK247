# Server
NODE_ENV=development
PORT=5000

# PostgreSQL — individual vars used by the app pool
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tek247_db
DB_USER=postgres
DB_PASSWORD=your_password

# DATABASE_URL — used by dbmate CLI for migrations
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/tek247_db?sslmode=disable

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_32_chars_min
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# Resend (email) — OPTIONAL. Leave RESEND_API_KEY unset to skip email sends
# (the server still boots; the Google/zkLogin demo path does not need email).
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tek247.app

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# CORS
CORS_ORIGIN=http://localhost:5173

# Google OAuth (must match the frontend / Enoki Google provider) — used to verify
# the Google ID token on /auth/enoki login.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Sui on-chain (TEK247) — see move/tek247/DEPLOYMENTS.md
SUI_NETWORK=testnet
SUI_FULLNODE_URL=https://fullnode.testnet.sui.io:443
USDC_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
SUI_PACKAGE_ID=0x64f7db7a66b5367947bd2a6b7e3751b0b6350dde7a12680903717a2052bff9e1
SUI_ARBITER_CAP_ID=0xa259366ad69332c5e0cb763ccc85b99c09e43cde8f8e6a10f152a57e3d26ad4e
SUI_ISSUER_CAP_ID=0xf735ea40ee482d48077150dbb3ec9cd59ca689ca576fd893eb1c994dd34e65a3
# Platform key (publisher/arbiter/issuer). Bech32 suiprivkey... — REQUIRED in prod
# for dispute resolution + passport issuance. Keep secret.
SUI_PLATFORM_SECRET_KEY=
