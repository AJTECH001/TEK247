# ─── TEK247 frontend env (Vite) ──────────────────────────────────────────────
# Copy to .env for local dev. In Vercel: Project → Settings → Environment Variables.

# Backend API base — MUST include the /api/v1 suffix.
# Local:  http://localhost:5000/api/v1
# Render: https://tek247-backend.onrender.com/api/v1
VITE_API_BASE_URL=http://localhost:5000/api/v1

# ─── Walletless login / sponsored gas (REQUIRED for the demo) ────────────────
# Enoki public API key + the Google OAuth client id wired into the Enoki portal.
VITE_ENOKI_API_KEY=enoki_public_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# zkLogin OAuth redirect (optional — defaults to <origin>/auth/zklogin/callback).
# If set, add it as an authorized redirect URI in Google AND allow-list it in Enoki.
# Prod example: https://tek247.vercel.app/auth/zklogin/callback
VITE_REDIRECT_URL=http://localhost:5173/auth/zklogin/callback

# ─── Sui on-chain (testnet) ──────────────────────────────────────────────────
VITE_SUI_NETWORK=testnet
VITE_SUI_PACKAGE_ID=0x64f7db7a66b5367947bd2a6b7e3751b0b6350dde7a12680903717a2052bff9e1
VITE_USDC_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
# Shop payout address (optional — has a built-in default)
# VITE_SHOP_ADDRESS=0xae680876f96824ade875f6d6523ab41d08df06abefa3c187079ae72b9df21a0c

# ─── Walrus (optional — public testnet defaults used if unset) ───────────────
# VITE_WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
# VITE_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
